#--------------------------------------------------------------------
# Example Environment Configuration File
#--------------------------------------------------------------------
# This file can be used as a starting point for your own .env file.
# Copy this file to .env and modify the values as needed.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
ci_environment = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080'
app.forceGlobalSecureRequests = false
app.sessionDriver = 'CodeIgniter\Session\Handlers\DatabaseHandler'
app.sessionCookieName = 'ci_session'
app.sessionExpiration = 7200
app.sessionSavePath = 'ci_sessions'
app.sessionMatchIP = false
app.sessionTimeToUpdate = 300
app.sessionRegenerateDestroy = false
app.CSRFProtection = true
app.CSRFTokenRandomize = false
app.CSRFHeaderName = 'X-CSRF-TOKEN'
app.CSRFCookieName = 'csrf_cookie_name'
app.CSRFExpire = 7200
app.CSRFRegenerate = true
app.CSRFExcludeURIs = []
app.CSRFSameSite = 'Lax'

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = sphere_db
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix = 
database.default.port = 3306
database.default.charset = utf8mb4
database.default.collation = utf8mb4_unicode_ci
database.default.persist = false
database.default.matchIP = false
database.default.busyTimeout = 0

#--------------------------------------------------------------------
# CONTENT SECURITY POLICY
#--------------------------------------------------------------------
CSP.default.reportOnly = false
CSP.default.baseURI = []
CSP.default.childSrc = []
CSP.default.connectSrc = []
CSP.default.defaultSrc = ['self']
CSP.default.fontSrc = []
CSP.default.formAction = []
CSP.default.frameAncestors = []
CSP.default.frameSrc = []
CSP.default.imgSrc = []
CSP.default.mediaSrc = []
CSP.default.objectSrc = []
CSP.default.pluginTypes = []
CSP.default.reportURI = []
CSP.default.require = []
CSP.default.scriptSrc = []
CSP.default.styleSrc = []
CSP.default.upgradeInsecureRequests = false

#--------------------------------------------------------------------
# COOKIE
#--------------------------------------------------------------------
cookie.expires = 0
cookie.path = /
cookie.domain = 
cookie.secure = false
cookie.httponly = true
cookie.samesite = 'Lax'
cookie.raw = false

#--------------------------------------------------------------------
# PROXYIPS
#--------------------------------------------------------------------
proxyIPs = ''

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
encryption.key = 
encryption.driver = OpenSSL
encryption.blockSize = 16
encryption.digest = SHA512

#--------------------------------------------------------------------
# HONEYPOT
#--------------------------------------------------------------------
honeypot.hidden = 'honeypot'
honeypot.label = 'Leave this field empty'
honeypot.name = 'bot'
honeypot.template = '<label>{label}</label><input type="text" name="{name}" value=""/>'
honeypot.container = '<div style="display:none">{template}</div>'

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------
security.tokenRandomize = false
security.csrfProtection = 'session'
security.csrfTokenName = 'csrf_token'
security.csrfHeaderName = 'X-CSRF-TOKEN'
security.csrfCookieName = 'csrf_cookie_name'
security.csrfExpire = 7200
security.csrfRegenerate = true
security.csrfRedirect = true
security.csrfSameSite = 'Lax'

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
logger.threshold = 4
logger.dateFormat = 'Y-m-d H:i:s'

#--------------------------------------------------------------------
# CURLRequest
#--------------------------------------------------------------------
curlrequest.shareOptions = true

#--------------------------------------------------------------------
# AUTHENTICATION - GOOGLE OAUTH
#--------------------------------------------------------------------
# Get these from Google Cloud Console
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID = 
GOOGLE_CLIENT_SECRET = 
GOOGLE_REDIRECT_URI = 'http://localhost:8080/auth/google/callback'

#--------------------------------------------------------------------
# EMAIL CONFIGURATION
#--------------------------------------------------------------------
email.SMTPHost = smtp.gmail.com
email.SMTPUser = your-email@gmail.com
email.SMTPPass = your-app-password
email.SMTPPort = 587
email.SMTPCrypto = tls
email.fromEmail = noreply@sphere.local
email.fromName = 'SPHERE System'

#--------------------------------------------------------------------
# PAGINATION
#--------------------------------------------------------------------
pager.perPage = 20

#--------------------------------------------------------------------
# STORAGE
#--------------------------------------------------------------------
# Maximum file upload sizes (in bytes)
upload.maxSize = 5242880
upload.allowedTypes = 'gif|jpg|jpeg|png|pdf|doc|docx|xls|xlsx'
upload.uploadPath = 'writable/uploads'

#--------------------------------------------------------------------
# FEATURE FLAGS
#--------------------------------------------------------------------
# Enable/disable system features
feature.googleOAuth = true
feature.emailNotifications = true
feature.documentExport = true
feature.qrCode = true
feature.analytics = true
